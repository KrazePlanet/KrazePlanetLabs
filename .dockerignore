# ============================================================
# .dockerignore - KrazePlanetLabs
# Excludes files that should not be copied into the image
# ============================================================

# Git
.git
.gitattributes
.gitignore

# Docker files themselves (no recursive nesting)
Dockerfile
docker-compose.yml
docker-compose.override.yml
.dockerignore

# OS-generated files
.DS_Store
Thumbs.db

# Logs (mounted as volumes)
logs/
*.log

# Temp/test files
*.zip
netlify.zip
test.txt
1606test.txt
_gen*.py
setup.ps1
vps_setup.sh

# Node (if any)
node_modules/

# IDE
.vscode/
.idea/
*.suo
*.user

# HackerOne reports (optional - comment out if you want included)
HackerOneReport/
