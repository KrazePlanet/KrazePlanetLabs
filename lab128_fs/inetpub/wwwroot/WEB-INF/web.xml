<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

  <display-name>DoD Personnel Records System</display-name>
  <description>GWT-based personnel management portal — DoD classified</description>

  <!-- Database connection -->
  <context-param>
    <param-name>db.host</param-name>
    <param-value>10.10.1.10</param-value>
  </context-param>
  <context-param>
    <param-name>db.port</param-name>
    <param-value>1433</param-value>
  </context-param>
  <context-param>
    <param-name>db.name</param-name>
    <param-value>DoDPersonnelDB</param-value>
  </context-param>
  <context-param>
    <param-name>db.user</param-name>
    <param-value>dod_app_user</param-value>
  </context-param>
  <!-- WARNING: plaintext credentials in deployment descriptor -->
  <context-param>
    <param-name>db.password</param-name>
    <param-value>D0D_App_S3rv1c3_2019!</param-value>
  </context-param>

  <!-- GWT CSS Servlet — VULNERABLE to path traversal via double URL encoding -->
  <servlet>
    <servlet-name>GwtCssServlet</servlet-name>
    <servlet-class>com.google.gwt.user.server.rpc.RemoteServiceServlet</servlet-class>
    <init-param>
      <param-name>staticRoot</param-name>
      <param-value>C:/inetpub/wwwroot/</param-value>
    </init-param>
  </servlet>

  <servlet-mapping>
    <servlet-name>GwtCssServlet</servlet-name>
    <url-pattern>/gwtmain/*</url-pattern>
  </servlet-mapping>

  <!-- Session config -->
  <session-config>
    <session-timeout>30</session-timeout>
  </session-config>

  <!-- Security constraint -->
  <security-constraint>
    <web-resource-collection>
      <web-resource-name>Admin Area</web-resource-name>
      <url-pattern>/admin/*</url-pattern>
    </web-resource-collection>
    <auth-constraint>
      <role-name>admin</role-name>
    </auth-constraint>
  </security-constraint>

</web-app>
